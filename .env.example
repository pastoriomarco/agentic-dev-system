# GitHub Webhook/App Configuration
GITHUB_WEBHOOK_SECRET=change-me
GITHUB_TOKEN=ghp_change_me
GITHUB_OWNER=pastoriomarco
GITHUB_REPO=agentic-dev-system
GITHUB_BASE_BRANCH=main
# Optional explicit allowlist (comma-separated full repo names)
# Example: ALLOWED_REPOS=pastoriomarco/agentic-dev-system,pastoriomarco/another-repo
# If empty and GITHUB_OWNER/GITHUB_REPO are set, that single repo is allowlisted by default.
ALLOWED_REPOS=

# Optional protection for manual approval/reject API endpoints
# If set, callers must pass header: X-Admin-Token: <value>
ADMIN_API_TOKEN=change-me

# Optional LLM endpoint/model for future integration
LLM_API_URL=http://localhost:8080/v1/chat/completions
LLM_MODEL=qwen3-coder-next

# Optional notifications
SLACK_WEBHOOK_URL=

# Redis-backed queue/session store
REDIS_URL=redis://redis:6379/0

# Placeholder for future SQL state backend
DATABASE_URL=sqlite:///agent_queue.db
