# GitHub Webhook/App Configuration
GITHUB_WEBHOOK_SECRET=change-me
# Runtime mode: set to production in deployed environments.
# When DEPLOYMENT_ENV=production, startup fails if GITHUB_WEBHOOK_SECRET is empty.
DEPLOYMENT_ENV=development
# Delivery id dedup retention window (seconds).
WEBHOOK_DELIVERY_TTL_SECONDS=86400
# Maximum accepted webhook payload size in bytes.
WEBHOOK_MAX_BODY_BYTES=262144
# Fixed-window ingress throttling for /webhook/github.
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_GLOBAL_MAX=120
WEBHOOK_RATE_LIMIT_REPO_MAX=60
GITHUB_TOKEN=ghp_change_me
GITHUB_OWNER=pastoriomarco
GITHUB_REPO=agentic-dev-system
GITHUB_BASE_BRANCH=main
# Optional explicit allowlist (comma-separated full repo names)
# Example: ALLOWED_REPOS=pastoriomarco/agentic-dev-system,pastoriomarco/another-repo
# If empty and GITHUB_OWNER/GITHUB_REPO are set, that single repo is allowlisted by default.
ALLOWED_REPOS=

# Protection for manual approval/reject API endpoints.
# Required when DEPLOYMENT_ENV=production.
ADMIN_API_TOKEN=change-me
GITHUB_STATUS_LABELS_ENABLED=true
GITHUB_STATUS_COMMENTS_ENABLED=true
GITHUB_ASSIGN_ON_PROCESSING=false
GITHUB_ASSIGNEE_LOGIN=
GH_LABEL_QUEUED=agent:queued
GH_LABEL_IN_PROGRESS=agent:in-progress
GH_LABEL_NEEDS_HUMAN=agent:needs-human
GH_LABEL_PR_OPENED=agent:pr-opened
GH_LABEL_FAILED=agent:failed
GH_LABEL_DEAD_LETTER=agent:dead-letter
GH_LABEL_REJECTED=agent:rejected

# Optional LLM endpoint/model for future integration.
# For a host-local LLM route, use host.docker.internal and set WORKER_ENABLE_HOST_GATEWAY=true below.
LLM_API_URL=http://host.docker.internal:8080/v1/chat/completions
LLM_MODEL=qwen3-coder-next
# Comma-separated exact hosts or dot-prefixed suffixes allowed for LLM_API_URL.
LLM_HOST_ALLOWLIST=host.docker.internal
AGENT_MAX_CHANGED_FILES=20
AGENT_MAX_DIFF_LINES=1500
AGENT_MAX_EDIT_ACTIONS=50
# Comma-separated prefixes; empty means unrestricted
AGENT_ALLOWED_PATH_PREFIXES=
# Comma-separated blocked prefixes/paths
AGENT_FORBIDDEN_PATH_PREFIXES=.git/,.github/workflows/,.env,secrets/
# Commands separated by ';;' (example below). If empty, auto-detection is used.
AGENT_QUALITY_COMMANDS=python -m pytest -q;;python -m ruff check .
AGENT_QUALITY_TIMEOUT_SECONDS=600
# Keep false in production unless intentionally allowing repos without tests/lint.
AGENT_ALLOW_NO_QUALITY_GATES=false
AGENT_PERMISSIONS_FILE=/app/AGENT_PERMISSIONS.md

# Optional notifications
SLACK_WEBHOOK_URL=

# Redis-backed queue/session store
REDIS_URL=redis://redis:6379/0
MAX_RETRIES=3
RETRY_BASE_DELAY_SECONDS=60
RETRY_MAX_DELAY_SECONDS=1800
RETRY_POLL_INTERVAL_SECONDS=15

# Per-task sandbox worker container settings
WORKER_IMAGE=agentic-dev-system:latest
WORKER_NETWORK=agent_worker_net
WORKER_TIMEOUT_SECONDS=1800
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=2g
WORKER_PIDS_LIMIT=256
WORKER_RUN_AS_UID=1000
WORKER_RUN_AS_GID=1000
# Set true only when the worker must reach a host-local LLM through host.docker.internal.
WORKER_ENABLE_HOST_GATEWAY=true
WORKER_ARTIFACTS_DIR=/worker-artifacts
WORKER_ARTIFACTS_VOLUME=worker-artifacts
WORKER_VOLUME_PREFIX=agent-task
WORKER_HTTP_PROXY=http://egress-proxy:3128
WORKER_HTTPS_PROXY=http://egress-proxy:3128
WORKER_NO_PROXY=localhost,127.0.0.1,host.docker.internal,egress-proxy,redis
DEEP_HEALTH_TIMEOUT_SECONDS=8
DEEP_HEALTH_GITHUB_URL=https://api.github.com/meta
DEEP_HEALTH_CHECK_LLM=false

# Placeholder for future SQL state backend
DATABASE_URL=sqlite:///agent_queue.db
